bundle:
  name: data-catalog

workspace:
  host: ${DATABRICKS_HOST}

artifacts:
  streamlit_app:
    type: whl
    path: .

resources:
  apps:
    data_catalog:
      name: data-catalog
      description: "Catálogo de Dados Profissional"
      resources:
        - name: streamlit-app
          description: "Streamlit Data Catalog Application"
          source_code_path: ./streamlit_app.py

targets:
  dev:
    mode: development
    workspace:
      host: ${DATABRICKS_HOST}

  prod:
    mode: production
    workspace:
      host: ${DATABRICKS_HOST}
      root_path: /Workspace/apps/data-catalog
